# Copy this file to .env and fill values before running.

# Preferred keys for run_from_csv.py
PROVIDER="openrouter"
OPENAI_KEY=""
OPENAI_MODEL="openai/gpt-4.1-mini"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"

