            }
            childColumns.put(innerName, childRef);
            if (childRef.granularity() != RowGranularity.PARTITION) {
                ValueIndexer<?> valueIndexer = value.valueIndexer(
                    table,
                    childRef,
                    getRef
                );
                innerIndexers.put(innerName, (ValueIndexer<Object>) valueIndexer);
            }
        }
    }

