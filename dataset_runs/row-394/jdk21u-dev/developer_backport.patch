diff --git a/test/jdk/sun/security/pkcs12/AttributesCorrectness.java b/test/jdk/sun/security/pkcs12/AttributesCorrectness.java
new file mode 100644
index 00000000000..70fb08124eb
--- /dev/null
+++ b/test/jdk/sun/security/pkcs12/AttributesCorrectness.java
@@ -0,0 +1,149 @@
+/*
+ * Copyright (c) 2023, Oracle and/or its affiliates. All rights reserved.
+ * DO NOT ALTER OR REMOVE COPYRIGHT NOTICES OR THIS FILE HEADER.
+ *
