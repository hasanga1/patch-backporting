    public MoveReferenceCastToLiteralCastOnAnyOperatorsWhenLeftIsReference() {
        this.castCapture = new Capture<>();
        this.pattern = typeOf(Function.class)
            .with(f -> AnyOperator.OPERATOR_NAMES.contains(f.name()))
