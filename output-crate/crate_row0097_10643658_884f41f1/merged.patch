         super(new InternalQueryProfileTree());
     }
+
+    /**
+     * @return a hierarchical representation of the profiled query tree
+     */
+    public synchronized List<ProfileResult> getTree() {
+        ArrayList<ProfileResult> results = new ArrayList<>(roots.size());
