+
+                    private int currentLineNumber = 0;
+
+                    @Override
+                    public String readLine() throws IOException {
+                        var line = super.readLine();
+                        currentLineNumber++;
+                        if (currentLineNumber > 1) {
+                            throw new EOFException("dummy");
+                        }
+                        return line;
+                    }
+                };
+            }
+        });
+
+
