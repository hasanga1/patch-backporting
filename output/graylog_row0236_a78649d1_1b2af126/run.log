                final String priString = matcher.group("pri");
                final Integer pri = Ints.tryParse(priString);
                final Map<String, Object> syslogFields = new HashMap<>();
                if (pri != null) {
                    final int facility = SyslogUtils.facilityFromPriority(pri);
