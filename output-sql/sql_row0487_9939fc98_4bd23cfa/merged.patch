+        switch (type) {
+          case INTEGER:
+          case SHORT:
+          case BYTE:
+            docValue = EnumUtils.convert(docValueExpr, Long.class);
+            break;
+          case FLOAT:
+            docValue = EnumUtils.convert(docValueExpr, Double.class);
+            break;
+          default:
+            // fallthrough
+        }
+      }
+      return docValue;
+    }
